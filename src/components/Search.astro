<div id="search" class="search-wrapper"></div>

<script is:inline>
  window.addEventListener('DOMContentLoaded', (event) => {
    const lang = document.documentElement.lang || 'ko';
    const isEn = lang === 'en';
    
    new PagefindUI({ 
      element: "#search", 
      showSubResults: true,
      translations: isEn ? {
        placeholder: "Search posts...",
        clear_search: "Clear",
        load_more: "Load more",
        search_label: "Search",
        filters_label: "Filters",
        zero_results: "No results found.",
        many_results: "Search results",
        one_result: "1 result found",
        total_zero_results: "No results",
        total_one_result: "1 result",
        total_many_results: "[COUNT] results",
        alt_search: "Showing alternative results.",
        search_suggestion: "Try a different search term.",
        searching: "Searching..."
      } : {
        placeholder: "포스팅 검색...",
        clear_search: "지우기",
        load_more: "더보기",
        search_label: "검색",
        filters_label: "필터",
        zero_results: "검색 결과가 없습니다.",
        many_results: "검색 결과",
        one_result: "검색 결과 1건",
        total_zero_results: "결과 없음",
        total_one_result: "결과 1건",
        total_many_results: "[COUNT]건의 결과",
        alt_search: "대체 검색어로 결과를 보여드립니다.",
        search_suggestion: "다른 검색어를 시도해 보세요.",
        searching: "검색 중..."
      }
    });
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text-color);
    --pagefind-ui-background: rgba(255, 255, 255, 0.03);
    --pagefind-ui-border: var(--border-color);
    --pagefind-ui-tag: var(--accent-light);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: 'Pretendard', sans-serif;
  }

  .search-wrapper {
    margin-bottom: 2rem;
  }

  .pagefind-ui .pagefind-ui__drawer {
    background: rgba(15, 17, 26, 0.95) !important;
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    padding: 1rem;
    margin-top: 0.5rem;
    max-height: 60vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(129, 140, 248, 0.3) transparent;
  }

  /* 결과 수 상태 텍스트 완전히 숨기기 */
  .pagefind-ui .pagefind-ui__status {
    display: none !important;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background: rgba(255, 255, 255, 0.05) !important;
    border: 1px solid var(--border-color) !important;
    color: #fff !important;
    font-weight: 500;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: var(--accent-light) !important;
    font-weight: 700 !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: var(--text-muted) !important;
    font-size: 0.9rem !important;
  }
</style>

<link href="/_pagefind/pagefind-ui.css" rel="stylesheet">
