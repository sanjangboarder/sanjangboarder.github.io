---
interface Props {
  lang?: 'ko' | 'en';
}

const { lang = 'ko' } = Astro.props;
---
<section class="giscus-wrapper glass">
  <script is:inline
    src="https://giscus.app/client.js"
    data-repo="sanjangboarder/sanjangboarder.github.io"
    data-repo-id="R_kgDOSYYI6g"
    data-category="Announcements"
    data-category-id="DIC_kwDOSYYI6s4C8sDf"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="transparent_dark"
    data-lang={lang}
    data-loading="lazy"
    crossorigin="anonymous"
    async>
  </script>
</section>

<style>
  .giscus-wrapper {
    margin-top: 5rem;
    padding: 3rem;
    border-radius: 1.5rem;
  }
</style>
