---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 게시글 데이터 가져오기 (최신순 6개)
const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 12); // 사이드바가 생겼으므로 더 많은 글을 보여줍니다.
---

<Layout title="산장보더 - Premium AI Fishing & Life Blog">
	<main class="container">
		<header class="hero">
			<div class="hero-content">
				<div class="badge">EST. 2000 • AI REBORN 2026</div>
				<h1 class="gradient-text">기록을 예술로,<br />경험을 정보로.</h1>
				<p class="hero-desc">
					26년 선상낚시의 정수와 스마트한 라이프 스타일.<br />
					산장보더의 모든 지식이 AI를 통해 고감도 콘텐츠로 재탄생합니다.
				</p>
			</div>
		</header>

		<section id="posts" class="posts-section">
			<div class="section-header">
				<h2 class="section-title">Latest Stories</h2>
			</div>

			<div class="posts-grid">
				{latestPosts.length > 0 ? (
					latestPosts.map((post) => (
						<article class="post-card glass">
							<a href={`/posts/${post.slug}`} class="card-link">
								<div class="card-content">
									<div class="card-meta">
										<span class="category-tag">{post.data.category}</span>
										<span class="card-date">{post.data.date.toLocaleDateString('ko-KR')}</span>
									</div>
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-desc">{post.data.description}</p>
									<div class="card-footer">
										<span class="read-more">Read Full Story</span>
										<div class="arrow-icon">→</div>
									</div>
								</div>
							</a>
						</article>
					))
				) : (
					<div class="no-posts glass">
						<p>아직 포스트가 없습니다. 마이그레이션된 글을 src/content/posts 폴더에 넣어주세요!</p>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Hero */
	.hero {
		padding: 80px 0 100px;
		position: relative;
	}
	.hero-content {
		max-width: 850px;
		text-align: left;
	}
	.badge {
		display: inline-block;
		padding: 0.5rem 1.25rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 100px;
		font-size: 0.7rem;
		font-weight: 700;
		color: var(--text-muted);
		letter-spacing: 0.15em;
		margin-bottom: 2.5rem;
	}
	.hero h1 {
		font-size: clamp(3rem, 8vw, 4.8rem);
		margin-bottom: 2.5rem;
		line-height: 1.05;
		color: #ffffff;
	}
	.hero-desc {
		font-size: 1.25rem;
		color: var(--text-muted);
		line-height: 1.8;
		max-width: 650px;
	}

	/* Posts Section */
	.posts-section {
		padding: 40px 0 100px;
	}
	.section-header {
		margin-bottom: 4rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 1rem;
	}
	.section-header h2 {
		font-size: 1.8rem;
		font-family: 'Outfit', sans-serif;
		color: #ffffff;
		letter-spacing: -0.01em;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 2.5rem;
	}

	.post-card {
		height: 100%;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		background: rgba(255, 255, 255, 0.02);
	}
	.post-card:hover {
		background: rgba(255, 255, 255, 0.04);
		transform: translateY(-10px);
	}
	
	.card-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		text-decoration: none;
	}

	.card-image {
		height: 220px;
		overflow: hidden;
		position: relative;
	}
	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.post-card:hover .card-image img {
		transform: scale(1.05);
	}

	.card-content {
		padding: 2rem;
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.card-meta {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-bottom: 1.25rem;
	}
	.category-tag {
		font-size: 0.65rem;
		font-weight: 800;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}
	.card-date {
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.3);
	}
	.card-title {
		font-size: 1.35rem;
		margin-bottom: 1rem;
		line-height: 1.4;
		font-weight: 700;
		color: #ffffff; /* 가독성을 위해 순수 흰색 적용 */
		transition: color 0.3s ease;
	}
	.post-card:hover .card-title {
		color: var(--accent-light);
	}
	.card-desc {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 2rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.card-footer {
		margin-top: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border-color);
	}
	.read-more {
		font-weight: 700;
		font-size: 0.8rem;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.arrow-icon {
		color: var(--text-muted);
		transition: transform 0.3s ease;
	}
	.post-card:hover .arrow-icon {
		transform: translateX(5px);
		color: var(--accent);
	}

	.no-posts {
		grid-column: 1 / -1;
		padding: 5rem;
		text-align: center;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.hero h1 { font-size: 2.5rem; }
		.posts-grid { grid-template-columns: 1fr; }
	}
</style>
