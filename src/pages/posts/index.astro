---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Archive - 산장보더">
  <main class="container">
    <div class="bg-orb orb-1"></div>
    
    <header class="archive-header">
      <h1 class="gradient-text">All Stories</h1>
      <p>{allPosts.length}개의 소중한 기록들이 담겨 있습니다.</p>
    </header>

    <div class="posts-list">
      {sortedPosts.map((post) => (
        <a href={`/posts/${post.slug}`} class="archive-item glass">
          <div class="date">{post.data.date.toLocaleDateString('ko-KR')}</div>
          <div class="content">
            <h3>{post.data.title}</h3>
            <span class="category">{post.data.category}</span>
          </div>
          <div class="arrow">→</div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .container {
    padding: 150px 2rem 80px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .archive-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .archive-header h1 {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .archive-item {
    display: flex;
    align-items: center;
    padding: 1.5rem 2.5rem;
    gap: 2rem;
  }

  .date {
    font-size: 0.9rem;
    color: var(--text-muted);
    min-width: 100px;
  }

  .content {
    flex: 1;
  }

  .content h3 {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .category {
    font-size: 0.75rem;
    color: var(--accent-light);
    font-weight: 700;
    text-transform: uppercase;
  }

  .arrow {
    font-size: 1.5rem;
    opacity: 0.3;
    transition: transform 0.3s;
  }

  .archive-item:hover .arrow {
    opacity: 1;
    transform: translateX(10px);
  }

  @media (max-width: 768px) {
    .archive-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1.5rem;
    }
  }
</style>
