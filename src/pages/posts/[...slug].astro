---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Giscus from '../../components/Giscus.astro';

// 모든 포스트를 가져와서 경로(slug) 생성
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('posts');
const matchingTranslation = post.data.logNo
  ? allPosts.find(p => p.data.logNo === post.data.logNo && (p.data.lang || 'ko') !== (post.data.lang || 'ko'))
  : null;
---

<Layout title={post.data.title} lang={post.data.lang || 'ko'}>
  <main class="post-container">
    <div class="bg-orb orb-1"></div>
    
    <article class="post-glass glass">
      <header class="post-header">
        {matchingTranslation && (
          <div class="lang-switcher-wrapper">
            <div class="lang-switcher glass">
              <span class={(post.data.lang || 'ko') === 'ko' ? "active" : ""}>
                {(post.data.lang || 'ko') === 'ko' ? "한국어" : <a href={`/posts/${matchingTranslation.slug}`}>한국어</a>}
              </span>
              <span class="separator">|</span>
              <span class={(post.data.lang || 'ko') === 'en' ? "active" : ""}>
                {(post.data.lang || 'ko') === 'en' ? "English" : <a href={`/posts/${matchingTranslation.slug}`}>English</a>}
              </span>
            </div>
          </div>
        )}
        <div class="post-meta">
          <span class="category">{post.data.category}</span>
          <time>{post.data.date.toLocaleDateString(post.data.lang === 'en' ? 'en-US' : 'ko-KR', post.data.lang === 'en' ? { year: 'numeric', month: 'long', day: 'numeric' } : {})}</time>
        </div>
        <h1 class="gradient-text">{post.data.title}</h1>
        { (post.data.source || post.data.logNo) && (
          <div class="original-link-wrapper">
            <a href={post.data.source || `https://blog.naver.com/sanjangboarder/${post.data.logNo}`} target="_blank" class="original-link">
              {post.data.lang === 'en' ? "Original Naver Blog Post" : "산장보더 네이버 블로그 원본글"}
            </a>
          </div>
        )}
      </header>


      <div class="post-body">
        <Content />
      </div>

      <Giscus />

      <footer class="post-footer">
        <a href={post.data.lang === 'en' ? "/en" : "/"} class="btn-back">← Back to Home</a>
        {post.data.source && (
          <a href={post.data.source} target="_blank" class="btn-source">Original Post ↗</a>
        )}
      </footer>
    </article>
  </main>
</Layout>

<style>
  .lang-switcher-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .lang-switcher a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s;
  }
  .lang-switcher a:hover {
    color: var(--accent-light);
  }
  .lang-switcher .active {
    color: var(--accent-light);
  }
  .lang-switcher .separator {
    color: rgba(255, 255, 255, 0.15);
  }
  .original-link-wrapper {
    text-align: right;
    margin-top: 1rem;
  }
  .original-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: underline;
    transition: color 0.3s;
  }
  .original-link:hover {
    color: var(--accent-light);
  }
  .post-container {
    padding: 120px 0 80px;
    max-width: 900px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .post-glass {
    padding: 4rem;
  }

  .post-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .post-meta {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .category {
    color: var(--accent-light);
    font-weight: 700;
    text-transform: uppercase;
  }

  .featured-image {
    margin: 2rem 0 4rem;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-body {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-color);
  }

  /* 마크다운 스타일링 */
  .post-body :global(p) { 
    margin-bottom: 1.5rem; 
    display: flow-root;
  }
  
  /* 연속된 이미지가 있는 단락 처리 */
  .post-body :global(p:has(img + img)) {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    margin: 2rem 0;
  }

  .post-body :global(img) { 
    max-width: 100%; 
    height: auto;
    border-radius: 0.5rem; 
    margin: 1rem auto;
    display: block;
    box-shadow: var(--shadow-sm);
  }

  /* 가로 나열 시 개별 이미지 마진 조정 */
  .post-body :global(p:has(img + img) img) {
    margin: 0;
    flex: 1;
    min-width: 250px;
    object-fit: cover;
  }

  .post-body :global(h2) { 
    font-size: 2rem; 
    margin: 4rem 0 1.5rem; 
    color: var(--accent-light);
  }

  .post-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
  }

  .btn-back, .btn-source {
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.3s;
  }

  .btn-back:hover, .btn-source:hover {
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .post-glass { padding: 2rem; }
    .gradient-text { font-size: 2rem; }
  }
</style>
