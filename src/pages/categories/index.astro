---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('posts');

// 카테고리별 포스트 개수 집계
const categoryCounts = allPosts.reduce((acc, post) => {
  const category = post.data.category || '미분류';
  acc[category] = (acc[category] || 0) + 1;
  return acc;
}, {});

const categories = Object.keys(categoryCounts).sort();
---

<Layout title="Categories - 산장보더">
  <main class="container">
    <div class="bg-orb orb-1"></div>
    
    <header class="page-header">
      <h1 class="gradient-text">Categories</h1>
      <p>관심 있는 주제를 선택해 보세요.</p>
    </header>

    <div class="category-grid">
      {categories.map((category) => (
        <a href={`/categories/${category}`} class="category-card glass">
          <div class="category-info">
            <span class="icon">📂</span>
            <h3>{category}</h3>
            <span class="count">{categoryCounts[category]} posts</span>
          </div>
          <div class="arrow">→</div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .container {
    padding: 150px 2rem 80px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .page-header h1 {
    font-size: 4rem;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .category-card {
    padding: 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .category-info h3 {
    font-size: 1.5rem;
    margin: 0.5rem 0;
  }

  .count {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .icon {
    font-size: 1.5rem;
  }

  .arrow {
    font-size: 1.5rem;
    opacity: 0.2;
    transition: transform 0.3s, opacity 0.3s;
  }

  .category-card:hover .arrow {
    opacity: 1;
    transform: translateX(10px);
  }
</style>
