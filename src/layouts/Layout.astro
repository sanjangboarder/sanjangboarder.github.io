---
import { getCollection } from 'astro:content';
import '../styles/global.css';

import Giscus from '../components/Giscus.astro';
import Search from '../components/Search.astro';

interface Props {
	title: string;
	description?: string;
	lang?: 'ko' | 'en';
}

const { title, description = "산장보더의 테크 & 라이프 블로그", lang = 'ko' } = Astro.props;

const isEn = lang === 'en';

// 카테고리 동적 추출
const allPosts = await getCollection('posts');
const categoryMap = new Map();
allPosts.forEach(post => {
  const postLang = post.data.lang || 'ko';
  if (postLang !== lang) return;
  const cat = post.data.category || (isEn ? 'Uncategorized' : '미분류');
  // Sample 카테고리는 목록 집계에서 제외
  if (cat === 'Sample') return;
  categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
});

// 포스팅 개수 내림차순으로 정렬
const categories = Array.from(categoryMap.entries()).sort((a, b) => {
  return b[1] - a[1];
});

// 전체 포스트 개수에서도 Sample 제외
const totalPosts = allPosts.filter(p => {
  const postLang = p.data.lang || 'ko';
  return postLang === lang && p.data.category !== 'Sample';
}).length;
---

<!doctype html>
<html lang={lang}>
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-0J8Y7BE5J7"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-0J8Y7BE5J7');
		</script>

		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="referrer" content="no-referrer" />
		<title>{title} | {isEn ? "Sanjangboarder" : "산장보더"}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@700;800&display=swap" rel="stylesheet">
		<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />

		<!-- Visitor Counter Script (Busuanzi) -->
		<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
		<!-- FontAwesome (Icons) -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
	</head>
	<body>
		<div class="app-layout">
			<!-- Sidebar -->
			<aside class="sidebar glass">
				<div class="sidebar-header">
					<a href={isEn ? "/en" : "/"} class="logo gradient-text">SANJANGBOARDER</a>
					<div class="social-links">
						<a href="https://www.instagram.com/sanjangboarder/" target="_blank" title="Instagram" class="social-icon instagram">
							<i class="fa-brands fa-instagram"></i>
						</a>
						<a href="https://blog.naver.com/sanjangboarder" target="_blank" title="Naver Blog" class="social-icon blog">
							<i class="fa-solid fa-n"></i>
						</a>
						<a href="https://in.naver.com/sanjangboarder" target="_blank" title="Influencer" class="social-icon influencer">
							<i class="fa-solid fa-user-check"></i>
						</a>
						<a href="https://www.youtube.com/@sanjangboarder" target="_blank" title="YouTube" class="social-icon youtube">
							<i class="fa-brands fa-youtube"></i>
						</a>
					</div>
				</div>
				
				<nav class="sidebar-nav">
					<div class="nav-section">
						<Search />
						<h3 class="nav-title">{isEn ? "Categories" : "카테고리"}</h3>
						<ul class="category-list">
							<li>
								<a href={isEn ? "/en" : "/"} class="category-item">
									<span class="cat-icon">📁</span>
									<span class="cat-name">{isEn ? "All Posts" : "전체보기"}</span>
									<span class="cat-count">({totalPosts})</span>
								</a>
							</li>
							<div class="divider"></div>
							{categories.map(([name, count]) => (
								<li>
									<a href={`/categories/${name}`} class="category-item">
										<span class="cat-icon">▫️</span>
										<span class="cat-name">{name}</span>
										<span class="cat-count">({count})</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</nav>

				<div class="sidebar-footer">
					<div class="visitor-stats">
						<div class="stat-item">
							<span class="stat-label">DAILY VIEW</span>
							<span id="busuanzi_value_site_pv" class="stat-value">...</span>
						</div>
						<div class="stat-sep"></div>
						<div class="stat-item">
							<span class="stat-label">TOTAL VISITORS</span>
							<span id="busuanzi_value_site_uv" class="stat-value">...</span>
						</div>
					</div>
					<a href="/about" class="footer-link">{isEn ? "About Me" : "소개"}</a>
				</div>
			</aside>

			<!-- Main Content -->
			<main class="main-content">
				<div class="bg-orb orb-1"></div>
				<slot />
			</main>
		</div>

		<!-- Naver Analytics -->
		<script type="text/javascript" src="//wcs.pstatic.net/wcslog.js"></script>
		<script type="text/javascript" is:inline>
		if(!wcs_add) var wcs_add = {};
		wcs_add["wa"] = "caba83efff3910";
		if(window.wcs) {
		  wcs_do();
		}
		</script>
	</body>
</html>
