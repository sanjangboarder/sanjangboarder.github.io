---
import { getCollection } from 'astro:content';
import '../styles/global.css';

import Giscus from '../components/Giscus.astro';
import Search from '../components/Search.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "산장보더의 테크 & 라이프 블로그" } = Astro.props;

// 카테고리 순서 정의 (사용자 요청 순서)
const ORDERED_CATEGORIES = [
  "바다낚시 팁/정보",
  "수도권 조행기",
  "전국구 조행기",
  "해루질 이야기",
  "낚시용품",
  "알리익스프레스",
  "IT기기/SW/드론",
  "장소/맛집",
  "이벤트/체험단",
  "자동차/오토모티브",
  "AI, SW개발, DevOps",
  "경제관련공부",
  "걷기다이어트",
  "겨울레저활동",
  "스포츠이야기",
  // "Sample" // 필요할 때 주석 해제
];

// 카테고리 동적 추출
const allPosts = await getCollection('posts');
const categoryMap = new Map();
allPosts.forEach(post => {
  const cat = post.data.category || '미분류';
  // Sample 카테고리는 목록 집계에서 제외
  if (cat === 'Sample') return;
  categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
});

// 정의된 순서에 따라 정렬, 목록에 없는 카테고리는 뒤로 보냄
const categories = Array.from(categoryMap.entries()).sort((a, b) => {
  const indexA = ORDERED_CATEGORIES.indexOf(a[0]);
  const indexB = ORDERED_CATEGORIES.indexOf(b[0]);
  
  if (indexA !== -1 && indexB !== -1) return indexA - indexB;
  if (indexA !== -1) return -1;
  if (indexB !== -1) return 1;
  return b[1] - a[1];
});

// 전체 포스트 개수에서도 Sample 제외
const totalPosts = allPosts.filter(p => p.data.category !== 'Sample').length;
---

<!doctype html>
<html lang="ko">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-0J8Y7BE5J7"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-0J8Y7BE5J7');
		</script>

		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="referrer" content="no-referrer" />
		<title>{title} | 산장보더</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@700;800&display=swap" rel="stylesheet">
		<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />

		<!-- Visitor Counter Script (Busuanzi) -->
		<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
		<!-- FontAwesome (Icons) -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
	</head>
	<body>
		<div class="app-layout">
			<!-- Sidebar -->
			<aside class="sidebar glass">
				<div class="sidebar-header">
					<a href="/" class="logo gradient-text">SANJANGBOARDER</a>
					<div class="social-links">
						<a href="https://www.instagram.com/sanjangboarder/" target="_blank" title="Instagram" class="social-icon instagram">
							<i class="fa-brands fa-instagram"></i>
						</a>
						<a href="https://blog.naver.com/sanjangboarder" target="_blank" title="Naver Blog" class="social-icon blog">
							<i class="fa-solid fa-n"></i>
						</a>
						<a href="https://in.naver.com/sanjangboarder" target="_blank" title="Influencer" class="social-icon influencer">
							<i class="fa-solid fa-user-check"></i>
						</a>
						<a href="https://www.youtube.com/@sanjangboarder" target="_blank" title="YouTube" class="social-icon youtube">
							<i class="fa-brands fa-youtube"></i>
						</a>
					</div>
				</div>
				
				<nav class="sidebar-nav">
					<div class="nav-section">
						<Search />
						<h3 class="nav-title">카테고리</h3>
						<ul class="category-list">
							<li>
								<a href="/" class="category-item">
									<span class="cat-icon">📁</span>
									<span class="cat-name">전체보기</span>
									<span class="cat-count">({totalPosts})</span>
								</a>
							</li>
							<div class="divider"></div>
							{categories.map(([name, count]) => (
								<li>
									<a href={`/categories/${name}`} class="category-item">
										<span class="cat-icon">▫️</span>
										<span class="cat-name">{name}</span>
										<span class="cat-count">({count})</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</nav>

				<div class="sidebar-footer">
					<div class="visitor-stats">
						<div class="stat-item">
							<span class="stat-label">VIEWS</span>
							<span id="busuanzi_value_site_pv" class="stat-value">...</span>
						</div>
						<div class="stat-sep"></div>
						<div class="stat-item">
							<span class="stat-label">VISITORS</span>
							<span id="busuanzi_value_site_uv" class="stat-value">...</span>
						</div>
					</div>
					<a href="/about" class="footer-link">About Me</a>
				</div>
			</aside>

			<!-- Main Content -->
			<main class="main-content">
				<div class="bg-orb orb-1"></div>
				<slot />
			</main>
		</div>
	</body>
</html>
